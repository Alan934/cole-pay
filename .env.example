# PostgreSQL connection string
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/colepay?schema=public"

# NextAuth / Auth.js — generar con: npx auth secret  (o cualquier string aleatorio largo)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL base de la app (en desarrollo)
AUTH_URL="http://localhost:3000"
